{
  "name": "aihub",
  "version": "0.1.0",
  "description": "Local aggregate API and CLI router for Gemini, Claude, and Codex subscriptions.",
  "type": "module",
  "bin": {
    "aihub": "./bin/aihub.js"
  },
  "main": "desktop/main/main.js",
  "scripts": {
    "start": "node ./bin/aihub.js service",
    "test": "node --test",
    "desktop": "concurrently -k -s first -n vite,electron \"vite --config desktop/renderer/vite.config.js --host 127.0.0.1\" \"wait-on http://127.0.0.1:5173 && electron .\"",
    "desktop:build": "vite build --config desktop/renderer/vite.config.js"
  },
  "engines": {
    "node": ">=22.13"
  },
  "keywords": [
    "gemini",
    "claude",
    "codex",
    "cli",
    "router"
  ],
  "license": "MIT",
  "dependencies": {
    "lucide-react": "^1.14.0",
    "react": "^19.2.6",
    "react-dom": "^19.2.6"
  },
  "devDependencies": {
    "@vitejs/plugin-react": "^6.0.1",
    "concurrently": "^9.2.1",
    "electron": "^42.0.1",
    "vite": "^8.0.12",
    "wait-on": "^9.0.10"
  }
}
